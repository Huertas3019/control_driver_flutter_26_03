rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regla general para cualquier colección
    match /{collection}/{docId} {
      // El usuario debe estar autenticado
      function isSignedIn() {
        return request.auth != null;
      }

      // El documento le pertenece al usuario
      function isOwner() {
        // Al leer, actualizar o borrar, comparamos con los datos existentes.
        return resource.data.userId == request.auth.uid;
      }

      // El nuevo documento que se crea le pertenecerá al usuario
      function isCreatingOwner() {
        // Al crear, comparamos con los datos que se están enviando.
        return request.resource.data.userId == request.auth.uid;
      }

      // Permisos
      allow read, update, delete: if isSignedIn() && isOwner();
      allow create: if isSignedIn() && isCreatingOwner();
    }
  }
}
